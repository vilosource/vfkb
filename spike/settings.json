{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "VTFKB_DIR=/tmp/vtfkb-spike-brain VTFKB_PROJECT=phase0-spike node /home/jasonvi/GitHub/vtfkb/dist/cli.js hook session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "VTFKB_DIR=/tmp/vtfkb-spike-brain node /home/jasonvi/GitHub/vtfkb/dist/cli.js hook pre-tool-use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "VTFKB_DIR=/tmp/vtfkb-spike-brain node /home/jasonvi/GitHub/vtfkb/dist/cli.js hook post-tool-use"
          }
        ]
      }
    ]
  }
}
