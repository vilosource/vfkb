{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "VFKB_DIR=/brain VFKB_PROJECT=devops-kb node /opt/vfkb/dist/cli.js hook session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /opt/vfkb/bash-guard.mjs"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "VFKB_DIR=/brain node /opt/vfkb/dist/cli.js hook pre-tool-use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "VFKB_DIR=/brain VFKB_PROJECT=devops-kb node /opt/vfkb/dist/cli.js hook post-tool-use"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Read", "Grep", "Glob", "Edit", "Write", "MultiEdit", "mcp__vfkb"]
  }
}
