node_modules/
dist/
coverage/
*.log
.vfkb-spike/

# vfkb's own committed design-brain (RFC-004 / ADR-0019): entries.jsonl is the
# git-committed SoR; the derived index is rebuildable and never committed (ADR-0014).
.vfkb/index-meta.json
.vfkb/.sessions/
.vfkb/.signals/
.vfkb/.journal/
.vfkb/.lock
.vfkb/.write-probe-*

# local registry auth (token via env)
.npmrc

# machine-local Claude Code config + operator tooling artifacts (never committed:
# settings.local.json / CLAUDE.local.md carry absolute per-machine paths; graphify-out/
# is a locally generated knowledge graph)
.claude/settings.local.json
CLAUDE.local.md
graphify-out/

# understand-anything: commit the graph artifacts, ignore the scratch/scan caches
.understand-anything/.trash-*/
.understand-anything/intermediate/
.understand-anything/tmp/
scenarios/records/*.log
scenarios/records/*.debug.*.txt
