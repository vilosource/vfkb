{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jasonvi/.local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jasonvi/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "vfkb": {
      "source": {
        "source": "github",
        "repo": "vilosource/vfkb-claude-plugin"
      }
    }
  },
  "enabledPlugins": {
    "vfkb@vfkb": true
  }
}
