{
  "extraKnownMarketplaces": {
    "vfkb": {
      "source": {
        "source": "github",
        "repo": "vilosource/vfkb-claude-plugin"
      }
    }
  },
  "enabledPlugins": {
    "vfkb@vfkb": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR:-.}/.claude/vfkb-guard.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR:-.}/scripts/hook-durable-claim-check.mjs"
          }
        ]
      }
    ]
  }
}
